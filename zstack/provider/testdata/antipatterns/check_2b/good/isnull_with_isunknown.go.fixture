package provider

import (
	"context"
	"github.com/hashicorp/terraform-plugin-framework/types"
)

// Good: IsNull() with IsUnknown() check on Int64 field
func goodInt64IsNullAndUnknown(ctx context.Context, data *struct {
	Timeout types.Int64
}) {
	if data.Timeout.IsNull() || data.Timeout.IsUnknown() {
		// Both checks present - OK
		return
	}
}

// Good: IsNull() with IsUnknown() check on Bool field
func goodBoolIsNullAndUnknown(ctx context.Context, data *struct {
	Enabled types.Bool
}) {
	if data.Enabled.IsNull() || data.Enabled.IsUnknown() {
		// Both checks present - OK
		return
	}
}

// Good: IsUnknown() alone is sufficient (no IsNull needed)
func goodIsUnknownOnly(ctx context.Context, data *struct {
	Port types.Int64
}) {
	if data.Port.IsUnknown() {
		// IsUnknown alone is OK
		return
	}
}
