func (r *check2aGoodVolumeResource) Update() {
	_, err := r.client.UpdateVolume("volume-uuid", nil)
	if err != nil {
		return
	}

	volume, err := r.client.GetVolume("volume-uuid")
	if err != nil {
		return
	}

	setStateFromAPIResponse(volume)
}

func (r *check2aGoodInstanceResource) Update() {
	_, err := r.client.UpdateInstance("instance-uuid", nil)
	if err != nil {
		return
	}

	instance, err := r.client.QueryInstance("instance-uuid")
	if err != nil {
		return
	}

	setStateFromAPIResponse(instance)
}

func setStateFromAPIResponse(value any) {}
