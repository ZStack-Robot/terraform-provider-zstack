# ZStack connection
export ZSTACK_HOST="your-zstack-host"
export ZSTACK_PORT="8080"

# Authentication: choose one of the two options below

# Option 1: AccessKey authentication (recommended)
export ZSTACK_ACCESS_KEY_ID="your-access-key-id"
export ZSTACK_ACCESS_KEY_SECRET="your-access-key-secret"

# Option 2: Account/Password authentication
# export ZSTACK_ACCOUNT_NAME="your-account"
# export ZSTACK_ACCOUNT_PASSWORD="your-password"

# Enable Terraform acceptance tests
export TF_ACC=1
